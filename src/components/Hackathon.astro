---
---

<section class="section-padding relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-r from-accent/5 via-transparent to-coral/5 pointer-events-none" />

  <div class="container-custom relative">
    <div class="glass-card border-accent/20 p-8 md:p-12 animate-on-scroll">
      <div class="flex items-center gap-3 mb-6">
        <span class="px-3 py-1 bg-amber/10 text-amber text-sm font-medium rounded-full border border-amber/20">
          National Level
        </span>
        <span class="px-3 py-1 bg-green/10 text-green text-sm font-medium rounded-full border border-green/20">
          2nd Place
        </span>
      </div>

      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        SAWiT.AI Hackathon
      </h2>

      <p class="text-xl text-muted mb-8 max-w-2xl">
        Built a fine-tuned TinyLlama model that translates English into casual, spoken Tamil — not formal textbook Tamil, but the way people actually text and talk.
      </p>

      <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-6 mb-8">
        <div>
          <p class="text-sm text-muted mb-1">Team</p>
          <p class="font-medium">Janis</p>
        </div>
        <div>
          <p class="text-sm text-muted mb-1">Prize</p>
          <p class="font-medium text-green">₹50,000</p>
        </div>
        <div>
          <p class="text-sm text-muted mb-1">Dataset</p>
          <p class="font-medium">72,000 samples</p>
        </div>
        <div>
          <p class="text-sm text-muted mb-1">Fine-tuning</p>
          <p class="font-medium">LoRA + 4-bit</p>
        </div>
      </div>

      <div class="flex flex-wrap gap-3 mb-8">
        <span class="px-3 py-1 bg-surface text-muted text-sm rounded-lg border border-border">Tamil</span>
        <span class="px-3 py-1 bg-surface text-muted text-sm rounded-lg border border-border">English</span>
        <span class="px-3 py-1 bg-surface text-muted text-sm rounded-lg border border-border">Tanglish</span>
        <span class="px-3 py-1 bg-surface text-muted text-sm rounded-lg border border-border">NLP</span>
        <span class="px-3 py-1 bg-surface text-muted text-sm rounded-lg border border-border">Fine-tuning</span>
        <span class="px-3 py-1 bg-surface text-muted text-sm rounded-lg border border-border">LLM</span>
      </div>

      <a
        href="https://huggingface.co/ThrishaSivasakthi/TinyLlama-1.1B-Chat-v1.0_1"
        target="_blank"
        class="btn-primary inline-flex"
      >
        View Model on HuggingFace
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  </div>
</section>
