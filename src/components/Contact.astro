<section id="contact" class="section-padding">
  <div class="container-custom text-center">
    <div class="animate-on-scroll">
      <p class="text-accent font-mono text-sm mb-3">Contact</p>
      <h2 class="section-title">Let's Build Something Together</h2>
      <p class="section-subtitle max-w-lg mx-auto">
        Open to opportunities, collaborations, and interesting conversations about AI/ML.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-12 max-w-4xl mx-auto">
      {contactLinks.map((link, index) => (
        <a
          href={link.href}
          target={link.href.startsWith('mailto') ? '_self' : '_blank'}
          class={`glass-card-hover p-6 text-center group animate-on-scroll stagger-${index + 1}`}
        >
          <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-surface border border-border flex items-center justify-center group-hover:border-accent/30 transition-colors">
            <svg class="w-5 h-5 text-muted group-hover:text-accent transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d={link.icon} />
            </svg>
          </div>
          <p class="text-sm text-muted mb-1">{link.label}</p>
          <p class="font-medium text-sm">{link.value}</p>
        </a>
      ))}
    </div>

    <div class="mt-12 animate-on-scroll">
      <a href="mailto:thrishasivasakthi@gmail.com" class="btn-primary text-lg px-8 py-4">
        Say Hello
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
